# ============================================================
#  87 TCS — VPS Environment
#  cp .env.example .env  rồi điền giá trị thật
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_HOST=localhost          # trên VPS: localhost hoặc IP container
POSTGRES_PORT=5555
POSTGRES_DB=m1087
POSTGRES_USER=m1087
POSTGRES_PASS=your-password

# ── Web Auth ──────────────────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# ── Worker mapper ─────────────────────────────────────────
MAPPER_INTERVAL_SEC=300          # quét mỗi 5 phút
MAPPER_WINDOW_SEC=120            # ±120s quanh gate event
MAPPER_LOOKBACK_HOURS=2          # mỗi lần quét 2h gần nhất
MAPPER_DEVICE_NAME=frigate-87tcs # khớp với devices.name trong DB

# Frigate credentials được lưu trong bảng devices (DB)
# Cập nhật bằng SQL sau khi chạy schema:
#   UPDATE devices SET password='real_pass' WHERE name='frigate-87tcs';

# ── Face recognition (bật sau) ────────────────────────────
FACE_ENABLED=false
COMPREFACE_URL=
COMPREFACE_KEY=
