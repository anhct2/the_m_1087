# .env.f87 — config cho f87 worker (KHÔNG commit file thật vào git)
# cp .env.f87.example .env.f87 rồi điền giá trị thật

# ── DB trên VPS HK ──────────────────────────────────────────
POSTGRES_HOST=<VPS_PUBLIC_IP>
POSTGRES_PORT=5555
POSTGRES_DB=m1087
POSTGRES_USER=m1087
POSTGRES_PASS=your-db-password

# ── Frigate — local trên f87 ────────────────────────────────
FRIGATE_URL=http://10.8.0.187:5000
FRIGATE_USER=admin
FRIGATE_PASS=Frigate87tcs

# ── Worker ──────────────────────────────────────────────────
WORKER_ID=worker-enroll-f87
POLL_INTERVAL_S=30
JOB_DELAY_S=90
MAX_CONCURRENT=2
LOG_LEVEL=INFO
LOG_FILE=/app/logs/worker_enroll.log
