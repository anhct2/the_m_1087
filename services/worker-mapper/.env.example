# Worker mapper chạy cùng VPS với PostgreSQL
# Credentials Frigate đọc từ bảng devices trong DB — không cần set ở đây

POSTGRES_HOST=localhost
POSTGRES_PORT=5555
POSTGRES_DB=m1087
POSTGRES_USER=m1087
POSTGRES_PASS=your-password

MAPPER_INTERVAL_SEC=300
MAPPER_WINDOW_SEC=120
MAPPER_LOOKBACK_HOURS=2
MAPPER_DEVICE_NAME=frigate-87tcs
