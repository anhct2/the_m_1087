# ── NVR Dahua ──────────────────────────────
NVR_IP=192.168.1.88
NVR_PORT=37777
NVR_USER=admin
NVR_PASS=admin123

# Camera channel index (0-based) trên NVR
CAM_N1_CHANNEL=0
CAM_S1_CHANNEL=1
CAM_S2_CHANNEL=2

# ── PostgreSQL (HK VPS qua WireGuard) ──────
DATABASE_URL=postgresql://user:pass@10.8.0.1:5432/the_m_1087

# ── Paths ───────────────────────────────────
SDK_LIB_PATH=/app/sdk/linux64/libdhnetsdk.so
VIDEO_OUTPUT_DIR=/data/videos
DAV_TEMP_DIR=/tmp/dav

# ── Worker ──────────────────────────────────
MAX_WORKERS=3
POLL_INTERVAL=10
SCHEDULER_INTERVAL=5
MAX_RETRIES=3
RETRY_DELAY=10

# ── NTP check (thông tin, không tự động) ────
# Đảm bảo f87 và NVR trỏ cùng NTP server
# Kiểm tra: chronyc tracking | grep "RMS offset"
